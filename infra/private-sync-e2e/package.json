{
  "name": "@formae/private-sync-e2e",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-only Playwright capture harness for SIGAA private sync.",
  "scripts": {
    "capture": "tsx src/cli.ts capture",
    "capture:headed": "tsx src/cli.ts capture --headed",
    "sync:web": "tsx src/cli.ts web-sync",
    "sync:web:headed": "tsx src/cli.ts web-sync --headed",
    "test": "tsx --test tests/sanitize.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^17.2.1",
    "playwright": "^1.55.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
