{
  "manifest_version": 3,
  "name": "Formaê SIGAA Sync",
  "version": "0.1.0",
  "description": "Sincronização local do SIGAA para o Formaê, com leitura privada no navegador e importação automática do histórico acadêmico.",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "Formae SIGAA Sync",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "data_collection_permissions": {
        "required": ["none"]
      },
      "id": "formae-extension@formae.local",
      "strict_min_version": "140.0"
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "background": {
    "scripts": ["src/background.js"],
    "service_worker": "src/background.js",
    "type": "module"
  },
  "permissions": ["scripting", "tabs"],
  "host_permissions": [
    "https://sigaa.ufba.br/*",
    "http://localhost/*",
    "https://mentorzx.github.io/*"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "https://mentorzx.github.io/*"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "https://mentorzx.github.io/*"
      ],
      "js": ["src/content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
