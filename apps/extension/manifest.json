{
  "manifest_version": 3,
  "name": "Formae SIGAA Sync Scaffold",
  "version": "0.1.0",
  "description": "Local-only SIGAA sync scaffold for Formae with bridge contracts and DOM extraction placeholders.",
  "action": {
    "default_title": "Formae SIGAA Sync",
    "default_popup": "src/popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "data_collection_permissions": {
        "required": ["none"]
      },
      "id": "formae-extension@formae.local",
      "strict_min_version": "140.0"
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "background": {
    "scripts": ["src/background.js"],
    "service_worker": "src/background.js",
    "type": "module"
  },
  "permissions": ["scripting", "tabs"],
  "host_permissions": [
    "https://sigaa.ufba.br/*",
    "http://localhost/*",
    "https://mentorzx.github.io/*"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "https://mentorzx.github.io/*"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "https://mentorzx.github.io/*"
      ],
      "js": ["src/content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
